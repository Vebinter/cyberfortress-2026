# CyberFortress 2026 — Конфигурация (ШАБЛОН)
# Скопируйте в .env и заполните реальными значениями

# GitHub API (для мониторинга репо)
GITHUB_TOKEN=your_token_here

# Telegram Bot (для уведомлений)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Крипто-кошельки (для донатов)
DONATE_BTC=your_btc_address
DONATE_ETH=your_eth_address
DONATE_USDT=your_usdt_address

# Локальные настройки
DATA_DIR=./data
LOG_LEVEL=INFO
